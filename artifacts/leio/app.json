{
  "expo": {
    "name": "Leio",
    "slug": "leio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "leio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#14110D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.leio.app"
    },
    "android": {
      "package": "com.leio.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o Leio use a câmera para escanear o código de barras dos livros."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o Leio acesse suas fotos para usar como capa do livro.",
          "cameraPermission": "Permitir que o Leio use a câmera para fotografar a capa do livro."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
